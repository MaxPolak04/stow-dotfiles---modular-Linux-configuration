" Colors
set termguicolors
syntax on

" Navigation and Interface
set number
set cursorline
set scrolloff=8
set showmatch
set mouse=a

" Searching
set incsearch
set hlsearch

" Indentations (Tabs and Spaces)
set expandtab
set tabstop=4
set shiftwidth=4
set autoindent

let g:catppuccin_flavour = "mocha"
colorscheme catppuccin

